DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_DEBUG=1
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

OPENAI_API_KEY=your_openai_api_key_here
# OpenAI

# Hugging Face (needed for gated models / higher rate limits)
HF_TOKEN=your_huggingface_token_here

# Default model IDs (override as needed)
NLLB_MODEL_ID=facebook/nllb-200-distilled-600M
XLMR_SIM_MODEL_ID=sentence-transformers/paraphrase-xlm-r-multilingual-v1

# Optional: AfroLingu-MT model ID (set if you have access)
AFROLINGU_MT_MODEL_ID=

# AfroLingu-MT dataset (benchmark). Note: requires accepting HF access conditions.
AFROLINGU_MT_DATASET_ID=UBC-NLP/AfroLingu-MT